#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RELEASE_BIN="$ROOT_DIR/wrapper/target/release/codexw"
REPO_BIN="$ROOT_DIR/bin/codexw"
INSTALL_BIN="${INSTALL_BIN:-/opt/homebrew/bin/codexw}"

cd "$ROOT_DIR/wrapper"
cargo build --release

cd "$ROOT_DIR"
cp "$RELEASE_BIN" "$REPO_BIN"
codesign --force --sign - "$REPO_BIN"

mkdir -p "$(dirname "$INSTALL_BIN")"
cp "$RELEASE_BIN" "$INSTALL_BIN"
codesign --force --sign - "$INSTALL_BIN"

echo "installed $INSTALL_BIN"
echo "repo copy $REPO_BIN"
